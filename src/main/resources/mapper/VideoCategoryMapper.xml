<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="mapper.VideoCategoryMapper">

    <!-- 定义 resultMap -->
    <resultMap id="categoryVideoCountMap" type="java.util.HashMap">
        <result property="categoryId" column="category_id" javaType="java.lang.Long"/>
        <result property="videoCount" column="video_count" javaType="java.lang.Long"/>
    </resultMap>

    <!-- 使用 resultMap -->
    <select id="getCategoryVideoCount" resultMap="categoryVideoCountMap">
        SELECT
            category_id,
            COUNT(*) as video_count
        FROM videos
        WHERE status = 1
        GROUP BY category_id
    </select>
    <select id="getTopCategories" resultType="com.kl_v.exam.entity.VideoCategory">
        SELECT * FROM video_categories
                 WHERE parent_id = 0 AND status = 1
                 ORDER BY sort_order ASC
    </select>
    <select id="getChildCategories" resultType="com.kl_v.exam.entity.VideoCategory">
        SELECT * FROM video_categories
                 WHERE parent_id = #{parentId} AND status = 1
                 ORDER BY sort_order ASC
    </select>
</mapper>