<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.kl_v.exam.mapper.QuestionChoiceMapper">
    <select id="selectListByQuestionId" resultType="com.kl_v.exam.entity.QuestionChoice">
        select * from question_choices where is_deleted = 0 and question_id = #{questionId} order by sort asc
    </select>
</mapper>