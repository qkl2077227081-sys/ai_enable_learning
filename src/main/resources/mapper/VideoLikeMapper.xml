<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="mapper.VideoLikeMapper">

    <select id="isLikedByIp" resultType="java.lang.Boolean">
        SELECT COUNT(*) > 0
        FROM video_likes
        WHERE video_id = #{videoId} AND user_ip = #{userIp}
    </select>
    <select id="getLikeCountByVideoId" resultType="java.lang.Long">
        SELECT COUNT(*)
        FROM video_likes
        WHERE video_id = #{videoId}
    </select>
</mapper>